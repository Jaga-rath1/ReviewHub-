<%- layout("/layouts/boilerplate") %>
<div class="container py-4">

    <div class="d-flex justify-content-end mb-4">
        <a href="/reviews/new" class="btn btn-danger">
            Write Review
        </a>
    </div>

    <% if(reviews.length > 0){ %>

        <% for(review of reviews){ %>

        <div class="card shadow-sm border-0 mb-4">

            <div class="card-body">

                <div class="d-flex align-items-center mb-3">

                    <div class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center fw-bold"
                         style="width:45px;height:45px;">
                        <%= review.username.charAt(0).toUpperCase() %>
                    </div>

                    <div class="ms-3">
                        <h6 class="mb-0 fw-bold">
                            <%= review.username %>
                        </h6>
                        <small class="text-muted">
                            Posted a review
                        </small>
                    </div>

                </div>

                <p class="fs-6 text-dark">
                    <%= review.message %>
                </p>

                <hr>

                <div class="d-flex justify-content-between">

                    <a href="/reviews/<%= review._id %>"
                       class="btn btn-outline-primary btn-sm">
                        View Details
                    </a>

                </div>

            </div>

        </div>

        <% } %>

    <% } else { %>

    <div class="text-center py-5">
        <h3>No Reviews Yet</h3>
        <p class="text-muted">
            Start the conversation by posting your first review.
        </p>

        <a href="/reviews/new" class="btn btn-primary">
            Write Review
        </a>
    </div>

    <% } %>

</div>