<%- layout("/layouts/boilerplate") %>
<div class="container py-5">

    <!-- Welcome -->
    <div class="p-5 mb-5 rounded-4 bg-dark text-white shadow">

        <h1 class="display-5 fw-bold">
            👋 Welcome, <%= curruser.username %>!
        </h1>

        <p class="lead mt-3">
            Manage your ReviewHub platform from one place.
            Create reviews, explore community posts, and manage your account.
        </p>

    </div>

    <!-- Dashboard Cards -->
    <div class="row g-4">

        <!-- All Reviews -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 shadow border-0 dashboard-card">

                <div class="card-body text-center">

                    <i class="bi bi-grid fs-1 text-primary"></i>

                    <h4 class="mt-3">
                        All Reviews
                    </h4>

                    <p class="text-muted">
                        Browse all reviews shared by the community.
                    </p>

                    <a href="/reviews" class="btn btn-primary">
                        Open
                    </a>

                </div>

            </div>
        </div>

        <!-- New Review -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 shadow border-0 dashboard-card">

                <div class="card-body text-center">

                    <i class="bi bi-pencil-square fs-1 text-success"></i>

                    <h4 class="mt-3">
                        Write Review
                    </h4>

                    <p class="text-muted">
                        Share your experience with everyone.
                    </p>

                    <a href="/reviews/new" class="btn btn-success">
                        Create
                    </a>

                </div>

            </div>
        </div>

        <!-- Logout -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 shadow border-0 dashboard-card">

                <div class="card-body text-center">

                    <i class="bi bi-box-arrow-right fs-1 text-danger"></i>

                    <h4 class="mt-3">
                        Logout
                    </h4>

                    <p class="text-muted">
                        Securely sign out of your account.
                    </p>

                    <a href="/logout" class="btn btn-danger">
                        Logout
                    </a>

                </div>

            </div>
        </div>

    </div>

</div>