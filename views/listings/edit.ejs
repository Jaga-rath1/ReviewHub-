<%- layout("/layouts/boilerplate") %>
<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7 col-md-9">

            <div class="card shadow">

                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0">Edit Review</h3>
                </div>

                <div class="card-body">

                    <p class="text-muted">
                        Update your review, <strong><%= review.username %></strong>.
                    </p>

                    <form
                        action="/reviews/<%= review._id %>?_method=PATCH"
                        method="POST"
                        class="needs-validation"
                        novalidate
                    >

                        <div class="mb-3">

                            <label class="form-label">
                                Username
                            </label>

                            <input
                                type="text"
                                class="form-control"
                                value="<%= review.username %>"
                                disabled
                            >

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Email
                            </label>

                            <input
                                type="email"
                                class="form-control"
                                value="<%= review.email %>"
                                disabled
                            >

                        </div>

                        <div class="mb-4">

                            <label class="form-label">
                                Review
                            </label>

                            <textarea
                                class="form-control"
                                name="message"
                                rows="6"
                                required
                            ><%= review.message %></textarea>

                            <div class="invalid-feedback">
                                Please enter your review.
                            </div>

                        </div>

                        <div class="d-flex justify-content-between">

                            <a
                                href="/reviews/<%= review._id %>"
                                class="btn btn-outline-secondary"
                            >
                                ← Back
                            </a>

                            <button
                                type="submit"
                                class="btn btn-warning"
                            >
                                Update Review
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>